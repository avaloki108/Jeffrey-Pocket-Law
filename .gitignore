# =========================
# SECRETS & SECURITY (CRITICAL)
# =========================
# Environment variables
.env
*.env
.env.*
!.env.example
android-app/.env
android-app/**/.env

# API Keys & Secrets code
secrets.dart
**/secrets.dart

# Keystores & Signing Keys (Global Safe-guards)
*.jks
*.keystore
*.p12
*.pem
key.properties
*.key.properties
keystore.properties
local.properties
**/local.properties
android-app/upload-keystore.jks
android-app/key.properties

# Firebase & Services (Often contain project IDs/Keys)
google-services.json
GoogleService-Info.plist
firebase.exe

# =========================
# FLUTTER & DART
# =========================
.dart_tool/
.packages
.pub-cache/
build/
**/build/
coverage/
lib/generated/
.flutter-plugins
.flutter-plugins-dependencies

# =========================
# ANDROID
# =========================
# Standard Android excludes
.gradle/
**/android/.gradle/
**/android/captures/
**/android/gradlew
**/android/gradlew.bat
**/android/gradle/
**/android/app/build/

# User specific Android paths
android/.gradle/
android/**/local.properties
android/**/gradlew*
android/**/gradle/wrapper/

# =========================
# IOS / MACOS
# =========================
ios/Pods/
macos/Pods/
**/Flutter/ephemeral/
.DS_Store

# =========================
# WEB / NODE / REACT
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
dist/
dist-ssr/
*-dist
*.local
.next/
out/
.cache/
.parcel-cache/
*.tsbuildinfo

# =========================
# IDE & TOOLS
# =========================
.idea/
.vscode/
!.vscode/extensions.json
*.iml
*.log
*.swp
*.suo
*.ntvs*
*.njsproj
*.sln
Thumbs.db
.sentryclirc
logs/
.spark-workbench-id

# =========================
# DATABASE & STORAGE
# =========================
# Hive
*.hive
*.lock.hive

# Qdrant (Vector DB)
/android-app/qdrant_storage/aliases/data.json
/android-app/qdrant_storage/collections/*/segments/*/payload_index/*/*
/android-app/qdrant_storage/collections/*/segments/*/version.info
/android-app/qdrant_storage/collections/*/wal/*
/android-app/qdrant_storage/collections/*/*.json
/android-app/qdrant_storage/collections/*/version.info
/android-app/qdrant_storage/.qdrant_fs_check
/android-app/qdrant_storage/raft_state.json

# DataConnect
dataconnect/.dataconnect/

# Misc
**/agent-eval-report*
packages
pids
.file-manifest
.devcontainer/
