# ==========================================
# Pocket Lawyer - Environment Configuration
# ==========================================
# Copy this file to .env and fill in your real keys
# NEVER commit the real .env file to git
# ==========================================

# --- AI Model Providers ---

# Groq (Primary for Jeffrey Persona)
GROQ_API_KEY=your-groq-api-key

# DeepSeek (Fallback)
DEEPSEEK_API_KEY=your-deepseek-api-key

# OpenRouter (Fallback)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=openai/gpt-4o-mini

# OpenAI (Legacy/Fallback)
OPENAI_API_KEY=your-openai-api-key

# Ollama (Local Fallback)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b

# --- Legal Data APIs ---

# LegiScan (State Laws)
LEGISCAN_API_KEY=your-legiscan-api-key

# Congress.gov (Federal Laws)
CONGRESS_GOV_API_KEY=your-congress-gov-api-key

# CourtListener (Case Law)
COURTLISTENER_API_KEY=your-courtlistener-api-key

# --- Optional / Future Integrations ---

PINECONE_API_KEY=your-pinecone-api-key
FIREBASE_API_KEY=your-firebase-api-key
REVENUECAT_API_KEY=your-revenuecat-api-key
MIXPANEL_TOKEN=your-mixpanel-token


